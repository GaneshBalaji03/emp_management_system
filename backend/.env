# Backend environment variables (DO NOT commit real secrets)
DB_NAME=hr_management
DB_USER=root
DB_PASSWORD=admin123
DB_HOST=localhost
DB_PORT=3306
# External auth/OTP endpoints (if applicable)
# these are required when your project uses an external authentication provider
LOGIN_THROUGH_PASSWORD_URL=replace_me
FORGET_PASSWORD_URL=replace_me
REGISTER_URL=replace_me
SEND_OTP_URL=replace_me
VERIFY_OTP_URL=replace_me

# legacy names (not used by code but left here for reference)
# AUTH_VERIFY_URL=replace_me
# OTP_REQUEST_URL=replace_me
# OTP_VERIFY_URL=replace_me

DATABASES = {
    'default': {
        'ENGINE': 'django.db.backends.mysql',
        'NAME': os.getenv('DB_NAME'),
        'USER': os.getenv('DB_USER'),
        'PASSWORD': os.getenv('DB_PASSWORD'),
        'HOST': os.getenv('DB_HOST'),
        'PORT': os.getenv('DB_PORT'),
    },
}

if not DATABASES['default'].get('NAME'):
    DATABASES['default'] = {
        'ENGINE': 'django.db.backends.sqlite3',
        'NAME': ':memory:',
    }
